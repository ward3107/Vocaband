{
  "extends": "./tsconfig.json",
  // Strict since 2026-06-11 (typecheck-debt cleanup): the unused-vars
  // overrides that used to live here are gone тАФ `noUnusedLocals` /
  // `noUnusedParameters` from the root tsconfig now apply in CI too,
  // and e2e/ + scripts/ are part of the checked set.
  //
  // server.ts is intentionally NOT a root here: it carries a handful of
  // known errors (Redis generics, Gemini schema typing) inside protected-
  // zone code that needs its owner's review to touch.  Those leftovers
  // plus one in src/core/supabase.ts are tracked by `.typecheck-baseline`
  // тАФ see scripts/typecheck-ratchet.sh.  Once they're fixed, the baseline
  // hits 0 and the ratchet behaves as a plain hard gate.
  "include": ["src", "e2e", "scripts", "vite.config.ts", "vitest.config.ts"]
}
