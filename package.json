{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "dev:vite": "vite",
    "dev:all": "dev.bat",
    "start": "NODE_ENV=production tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "typecheck": "tsc --noEmit",
    "typecheck:ci": "tsc --noEmit -p tsconfig.ci.json",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "npx playwright test --config e2e/playwright.config.ts --ui",
    "audit": "npm audit",
    "gen:types": "npx supabase gen types typescript --project-id $SUPABASE_PROJECT_REF --schema public > src/core/supabase-types.generated.ts",
    "install:prod": "npm install --legacy-peer-deps",
    "deploy:preview": "npm run build && wrangler deploy --config dist/vocaband/wrangler.json --name vocaband-preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.0",
    "@floating-ui/react": "^0.27.19",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.105.3",
    "@tailwindcss/vite": "^4.2.4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/multer": "^2.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "canvas-confetti": "^1.9.4",
    "csvtojson": "^2.0.14",
    "date-fns": "^4.1.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "howler": "^2.2.4",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.38.0",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "pptxgenjs": "^4.0.1",
    "qrcode-generator": "^2.0.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.6",
    "react-parallax-tilt": "^1.7.327",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "overrides": {
    "serialize-javascript": "^7.0.4",
    "@xmldom/xmldom": "^0.8.13",
    "postcss": "^8.5.10",
    "ip-address": "^10.1.1",
    "fast-uri": "^3.1.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/howler": "^2.2.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "google-tts-api": "^0.0.6",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "serialize-javascript": "^7.0.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^0.19.8",
    "vitest": "^4.1.5"
  }
}
