# ALLOWED_ORIGIN: The origin URL for CORS restrictions on the WebSocket server.
# Defaults to http://localhost:3000 if not set.
ALLOWED_ORIGIN="http://localhost:3000"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# Supabase — server-side (Node.js / server.ts)
# Find these in: Supabase Dashboard → Settings → API
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Supabase — client-side (Vite / browser)
# These are safe to expose to the browser (the anon key is protected by RLS).
# Create a .env file (not committed) with these values for local dev.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# Optional: restrict teacher auto-creation to specific email domains (comma-separated).
# When set, only Google accounts with a matching domain can sign in as teachers.
# Leave unset to allow any Google account (less secure — suitable for testing only).
# Example: VITE_ALLOWED_TEACHER_DOMAINS="myschool.edu,district.org"
VITE_ALLOWED_TEACHER_DOMAINS=""
