# ALLOWED_ORIGIN: The origin URL for CORS restrictions on the WebSocket server.
# Defaults to http://localhost:3000 if not set.
ALLOWED_ORIGIN="http://localhost:3000"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"        

# Supabase — server-side (Node.js / server.ts)
# Find these in: Supabase Dashboard → Settings → API
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Supabase — client-side (Vite / browser)
# These are safe to expose to the browser (the anon key is protected by RLS).
# Create a .env file (not committed) with these values for local dev.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# Cloudflare CDN — for cached motivational audio files
# This provides better performance and caching than Supabase storage
# Example: https://your-bucket.r2.dev or https://https://your-custom-domain.com
VITE_CLOUDFLARE_URL="https://your-cloudflare-r2-url.dev"

# API URL — the Render server URL for Socket.IO and /api/* calls
# In production (Cloudflare Pages), set this to your Render API domain.
# In dev, leave empty to use same-origin (Vite proxy handles it).
VITE_API_URL=""

# Google Cloud Translation API — for auto-translating custom words (SERVER-SIDE)
# Get your free API key at: https://console.cloud.google.com/apis/library/translate.googleapis.com
# Free tier: 500,000 characters/month (~25,000 words)
# This key stays on the server and is NEVER exposed to the browser
GOOGLE_TRANSLATE_API_KEY=""

# OCR is handled by Tesseract.js (built-in, no external service needed)

# Anthropic Claude API — for AI sentence generation in Sentence Builder (SERVER-SIDE)
# Get your API key at: https://console.anthropic.com/settings/keys
# Uses Claude Haiku (cheapest model), ~$1.50/year estimated cost.
# This key stays on the server and is NEVER exposed to the browser.
# AI access is also gated per-teacher via the `ai_allowlist` table in Supabase.
ANTHROPIC_API_KEY=""

# Teacher access is controlled via the `teacher_allowlist` table in Supabase.
# Add teacher emails directly in the Supabase SQL Editor:
#   INSERT INTO public.teacher_allowlist (email) VALUES ('teacher@example.com');
#
# Premium features (AI sentence generation AND OCR) are gated via the
# `ai_allowlist` table. Only teachers whose email is in this table can use
# these features. Same list controls both:
#   INSERT INTO public.ai_allowlist (email) VALUES ('teacher@example.com');
