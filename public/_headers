# Security headers for Cloudflare Pages
# These apply when SKIP_STATIC=true on Render (Pages serves the SPA)
#
# CSP notes (2026-05-08, Phase 6 — full unsafe-* removal):
#   * script-src     — `'unsafe-eval'` and `'unsafe-inline'` BOTH dropped.
#                      Production bundle has no eval/new Function. The one
#                      inline boot script moved to /boot-debug.js. Cloudflare
#                      Insights auto-injects an external <script src=...> to
#                      static.cloudflareinsights.com (host-allowlisted below).
#   * style-src-elem — `'unsafe-inline'` dropped. Only external <link rel=
#                      stylesheet> is allowed; inline boot styles moved to
#                      /boot.css.
#   * style-src-attr — `'unsafe-inline'` KEPT. motion/react animates by
#                      writing transform/opacity to the element's `style`
#                      attribute every frame. CSS-only — cannot escalate to
#                      JS execution. The narrowest practical CSP given a
#                      runtime animation library; dropping it would require
#                      replacing motion/react with keyframe CSS classes.

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 0
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(self), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: same-site
  X-Permitted-Cross-Domain-Policies: none
  Content-Security-Policy: default-src 'self'; script-src 'self' https://static.cloudflareinsights.com https://challenges.cloudflare.com; script-src-elem 'self' https://static.cloudflareinsights.com https://challenges.cloudflare.com; style-src-elem 'self' https://fonts.googleapis.com; style-src-attr 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://auth.vocaband.com wss://auth.vocaband.com https://api.vocaband.com wss://api.vocaband.com https://vocaband.fly.dev wss://vocaband.fly.dev https://*.supabase.co wss://*.supabase.co https://static.cloudflareinsights.com https://cloudflareinsights.com https://vocaband.com wss://vocaband.com https://challenges.cloudflare.com; media-src 'self' https://auth.vocaband.com https://*.supabase.co https://*.cloudflare.com; worker-src 'self' blob:; frame-src https://accounts.google.com https://challenges.cloudflare.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self' https://accounts.google.com

# Cache static assets aggressively (hashed filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Don't cache HTML (SPA routing)
/index.html
  Cache-Control: no-cache

# Don't cache service worker
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
