# Supabase migration credentials — copy to .env.migrate and fill in.
# .env.migrate is git-ignored. Never commit real values.

# ── Tokyo (source — where the data is now) ───────────────────────────────
# Connection string: Supabase dashboard → Tokyo project →
#   Project Settings → Database → Connection string → tab "URI".
# It looks like postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
TOKYO_DB_URL=
# Service role key: Tokyo project → Project Settings → API → service_role
# (click "Reveal" — long JWT starting with eyJ)
TOKYO_SERVICE_ROLE_KEY=
# Base REST URL, e.g. https://<tokyo-ref>.supabase.co
TOKYO_URL=

# ── Frankfurt (target — where we're migrating to) ────────────────────────
# Same three fields for the new Frankfurt project.
FRANKFURT_DB_URL=postgresql://postgres:<frankfurt-password>@db.ilbeskwldyrleltnxyrp.supabase.co:5432/postgres
FRANKFURT_SERVICE_ROLE_KEY=
FRANKFURT_URL=https://ilbeskwldyrleltnxyrp.supabase.co
