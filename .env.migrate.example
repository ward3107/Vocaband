# Supabase migration credentials — copy to .env.migrate and fill in.
# .env.migrate is git-ignored. Never commit real values.
#
# Fields are stored as separate parts (host, password, etc.) instead of
# as a full postgres://user:password@host/db URL. GitHub's secret
# scanner matches that URL shape even when the password is a placeholder,
# so we sidestep it by never putting host+password on the same line. The
# migrate-db.sh script reassembles the connection URL internally.

# ── Tokyo (source — where the data is now) ───────────────────────────────
# Find these in Supabase dashboard → Tokyo project:
#   Project Settings → Database → Connection string → tab "URI"
#     TOKYO_DB_HOST     = the db.xxx.supabase.co host (no protocol prefix)
#     TOKYO_DB_PASSWORD = the password embedded in that URI
#   Project Settings → API:
#     TOKYO_SERVICE_ROLE_KEY = the service_role JWT (click Reveal)
#     TOKYO_URL              = the Project URL (starts with https://)
TOKYO_DB_HOST=
TOKYO_DB_PASSWORD=
TOKYO_SERVICE_ROLE_KEY=
TOKYO_URL=

# ── Frankfurt (target — where we're migrating to) ────────────────────────
# Same four fields for the new Frankfurt project.
FRANKFURT_DB_HOST=
FRANKFURT_DB_PASSWORD=
FRANKFURT_SERVICE_ROLE_KEY=
FRANKFURT_URL=
