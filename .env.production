# Public, build-time Vite values. All three keys here are already
# visible to every visitor inside dist/assets/*.js — Vite bakes them
# into the bundle at build time. Committing them guarantees every
# branch build (main + preview) gets the same values without having
# to split Cloudflare's build-env secrets per environment.
#
# Secrets that must NOT be in this file:
#   - SUPABASE_SERVICE_ROLE_KEY  (stays on Render, server-only)
#   - ANTHROPIC_API_KEY          (stays on Render)
#   - GOOGLE_AI_API_KEY          (stays on Render)
#
# If you need to rotate VITE_SUPABASE_ANON_KEY, edit it here and push —
# every build from that commit forward uses the new key.

VITE_SUPABASE_URL=https://auth.vocaband.com
VITE_SUPABASE_ANON_KEY=sb_publishable_O1immSThDxWWI6PNXPNi1w__27CAThD
VITE_SOCKET_URL=https://api.vocaband.com

# Quick Play v2 — route kick/end-session + leaderboard over the socket.io
# /quick-play namespace instead of Supabase Realtime on the progress
# table. v1 kicks were unreliable because DELETE events omit student_uid
# unless the table has REPLICA IDENTITY FULL (it doesn't), so the
# student-side listener `payload.old.student_uid === uid` check silently
# returned false and kicked students kept playing. v2 sidesteps that
# entirely with a direct KICKED / SESSION_ENDED socket event.
VITE_QUICKPLAY_V2=true

# Classroom v2 — four task-oriented tabs (Today / Students / Assignments
# / Reports) instead of the legacy Pulse + Mastery split. Teachers in
# the pilot reported the legacy naming was confusing ("Pulse" heard as
# "Polls"); v2 maps tab names directly to the question each tab
# answers. The legacy 2-tab layout stays in the codebase as a fallback
# if this flag is flipped off.
VITE_CLASSROOM_V2=true
